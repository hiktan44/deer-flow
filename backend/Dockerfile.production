# Backend Production Dockerfile — Coolify uyumlu
# Config dosyaları build sırasında kopyalanır, volume mount gerekmez
FROM python:3.12-slim

ARG NODE_MAJOR=22

# Install system dependencies + Node.js (provides npx for MCP servers)
RUN apt-get update && apt-get install -y \
    curl \
    build-essential \
    gnupg \
    ca-certificates \
    && mkdir -p /etc/apt/keyrings \
    && curl -fsSL https://deb.nodesource.com/gpgkey/nodesource-repo.gpg.key -o /etc/apt/keyrings/nodesource.gpg \
    && echo "deb [signed-by=/etc/apt/keyrings/nodesource.gpg] https://deb.nodesource.com/node_${NODE_MAJOR}.x nodistro main" > /etc/apt/sources.list.d/nodesource.list \
    && apt-get update \
    && apt-get install -y nodejs \
    && rm -rf /var/lib/apt/lists/*

# Install uv
COPY --from=ghcr.io/astral-sh/uv:0.7.20 /uv /uvx /usr/local/bin/

# Set working directory
WORKDIR /app

# Copy backend source
COPY backend ./backend

# Copy production config files INTO the image
COPY config.production.yaml ./backend/config.yaml
COPY config.production.yaml ./config.yaml
COPY extensions_config.production.json ./backend/extensions_config.json
COPY extensions_config.production.json ./extensions_config.json

# Copy skills
COPY skills ./skills

# Install dependencies with cache mount
RUN --mount=type=cache,target=/root/.cache/uv \
    sh -c "cd backend && uv sync && uv add langgraph-checkpoint-postgres psycopg[binary] psycopg-pool"

# Expose ports (gateway: 8001, langgraph: 2024)
EXPOSE 8001 2024

# Default command
CMD ["sh", "-c", "cd backend && uv run uvicorn src.gateway.app:app --host 0.0.0.0 --port 8001"]
